# Smart Al-Idara Pro — environment variables
# -------------------------------------------------------------------
# أين الملفات؟ في جذر المشروع فقط (بجانب package.json): `.env`, `.env.local`, `.env.production`.
# لا يوجد مجلد `env/` — هذا هو المعيار في Vite و Node (`loadEnv` و `dotenv` يقرآن من cwd الجذر).
# لا تنقل هذه الملفات إلى مجلد فرعي بدون تعديل vite.config و server؛ الإبقاء في الجذر صحيح.
#
# • Local: copy to `.env` (and optionally `.env.local`) at the repo root.
# • Never commit real secrets. This file is the only env template in git.
# • `VITE_*` are baked into the client at `npm run build` / `vite build`.
# • Server vars are read by `server/index.ts` (local `tsx watch` or Vercel `api/index.ts`).
#
# Vercel: Project → Settings → Environment Variables
#   Add Production + Preview + Development as needed. Vercel does not read `.env.production`
#   from the repo; mirror important vars there for deploys.
#
# Architecture:
#   • Production: static SPA from `dist/` + serverless Express at `api/index.ts` → same origin `/api/...`.
#   • Local dev: `npm run dev` = Vite (client) + Express on PORT (default 4000).
# -------------------------------------------------------------------


# =============== CLIENT (Vite) — REQUIRED for auth & app ===============

# Supabase: Project Settings → API (Project URL + anon public key).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production site URL, no trailing slash (magic links, redirects, share URLs).
# Example: https://your-domain.com
VITE_PUBLIC_APP_URL=


# =============== CLIENT (Vite) — OPTIONAL ===============

# Sub-path hosting only; must start with `/`. Default is `/`.
# VITE_BASE_PATH=/

# Same-origin default: leave unset so the app calls `/api`.
# Use only if the SPA is on a different host than the API (full prefix, no trailing slash).
# VITE_API_URL=https://api.example.com/api

# Admin bootstrap (must match server ADMIN_BOOTSTRAP_KEY; 16+ chars if you enable bootstrap).
# VITE_ADMIN_BOOTSTRAP_KEY=
# VITE_ADMIN_AUTO_LOGIN=true

# Optional UI override for displayed super-admin email (server still enforces real admin).
# VITE_SUPER_ADMIN_EMAIL=


# =============== SERVER (Express — local + Vercel serverless) ===============
# On Vercel, set these in the dashboard (same names). The API bundle uses `server/index.ts`.

PORT=4000

# JWT signing — MUST be a long random string in production.
JWT_SECRET=change-me-generate-a-long-random-string
JWT_EXPIRES_DAYS=365

# Primary super-admin (email must match your bootstrap / first admin account).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=
SUPER_ADMIN_WHATSAPP=

# Optional: longer-lived primary admin token (years).
# PRIMARY_ADMIN_JWT_YEARS=10

# One-time admin bootstrap from the client (optional).
ADMIN_BOOTSTRAP_KEY=

# Supabase: server can use these names (or fall back to VITE_* if unset).
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# OpenAI (AI features in server routes).
# OPENAI_API_KEY=

# Optional: encrypt sensitive fields at rest (hex key).
# FIELD_ENCRYPTION_KEY=

# CORS / auth: canonical URL (can mirror VITE_PUBLIC_APP_URL).
# PUBLIC_APP_URL=
# AUTH_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# AUTH_STRICT_ORIGIN=true

# Session cookie duration helpers (see server code for defaults).
# REMEMBER_ME_YEARS=5

# Optional integrations (only if you use those modules).
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# SHOTSTACK_API_KEY=
# SHOTSTACK_BASE_URL=https://api.shotstack.io/v1
# PROMO_MUSIC_URL=

# Subscription UI defaults (server).
# SUBSCRIPTION_PERIOD_DAYS=30

# Used by some internal URLs when PUBLIC_API_URL unset (local tooling).
# PUBLIC_API_URL=


# =============== Vercel deploy checklist (auth + API) ===============
# 1) Node.js version MUST be 22.x (the API uses `node:sqlite`, added in Node 22.5+).
#    Vercel → Project → Settings → General → Node.js Version → 22.x
#    Then **Redeploy** (changing only env vars does not always change the Functions runtime).
# 2) In Environment Variables use the **Project** tab for values you care about; **Shared**
#    entries that show "Overridden by Project" are ignored in favor of Project values.
# 3) Copy the **same** values you use locally into Vercel (do not invent new keys for Supabase/JWT).
#    Minimum for login (Supabase + exchange with API):
#      VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_PUBLIC_APP_URL, JWT_SECRET, JWT_EXPIRES_DAYS
#    Recommended duplicates for the serverless API (same values as the VITE_ pair):
#      SUPABASE_URL=<same as VITE_SUPABASE_URL>
#      SUPABASE_ANON_KEY=<same as VITE_SUPABASE_ANON_KEY>
# 4) VITE_PUBLIC_APP_URL = the exact public URL users open (no trailing slash), e.g.
#      https://your-project.vercel.app   OR   https://your-custom-domain.com
#    Add the same URL(s) in Supabase → Authentication → URL configuration (Site URL + Redirect URLs).
# 5) After changing any `VITE_*` variable, trigger a **new production build** so the client bundle picks it up.
# 6) Optional: OPENAI_API_KEY, SUPER_ADMIN_*, ADMIN_BOOTSTRAP_KEY, CLOUDINARY_* — only if you use those features.

# =============== Local run notes ===============
# • `npm run start` uses NODE_OPTIONS=--experimental-sqlite — keep if your deployment runs Node directly.
# • Use Node 22 locally (`nvm use` / see `.nvmrc`) to match Vercel.
# • If ports 5173 or 4000 are busy: `npm run kill:dev-ports` then `npm run dev`.
