# Smart Al-Idara Pro — environment variables
# -------------------------------------------------------------------
# Copy to `.env` at the repo root. Never commit real secrets.
# Naming convention: `VITE_*` are inlined into the client bundle at
# build time. Everything else (PORT, JWT_SECRET, …) is server-only.
# On Vercel, set the VITE_* vars in Project → Settings →
# Environment Variables (Production + Preview + Development).
# -------------------------------------------------------------------


# =============== CLIENT (Vite) — REQUIRED ===============

# Supabase project (Authentication → URL + anon/public key).
# URL format: https://<project-ref>.supabase.co
# Anon key is the `anon` / `public` key — a JWT starting with `eyJ…`.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Canonical production URL (no trailing slash). Used for referral
# links, TL magic links, `/dept/…` share URLs, and Supabase email /
# OAuth redirects. Set to your domain, e.g. https://smartal-idarapro.com
VITE_PUBLIC_APP_URL=


# =============== CLIENT (Vite) — OPTIONAL ===============

# Set only when the SPA is served under a sub-path (must have leading
# slash). Default "/" means served at domain root.
# VITE_BASE_PATH=/

# Override the API origin when the SPA and API are on different hosts.
# Leave unset to use same-origin `/api`.
# Split host example: VITE_API_URL=https://api.smartal-idarapro.com/api
# VITE_API_URL=

# Passwordless admin bootstrap (must match server ADMIN_BOOTSTRAP_KEY, 16+ chars).
# Enables a POST /api/auth/admin-bootstrap call from the client.
# VITE_ADMIN_BOOTSTRAP_KEY=
# VITE_ADMIN_AUTO_LOGIN=true

# Override the displayed super-admin email (server-side value still wins).
# VITE_SUPER_ADMIN_EMAIL=lahcenm534@gmail.com


# =============== SERVER (Node API) — NOT deployed to Vercel ===============
# The Node server in `server/index.ts` runs locally (`npm run dev:server`)
# or must be hosted separately (Render / Railway / Fly / VM). Vercel only
# serves the static `dist/` bundle.

PORT=4000
SUPER_ADMIN_EMAIL=lahcenm534@gmail.com
SUPER_ADMIN_WHATSAPP=+212780290270
SUPER_ADMIN_NAME=LAHCEN EL MOUTAOUAKIL
SUPER_ADMIN_PASSWORD=
JWT_SECRET=change-me-in-production
JWT_EXPIRES_DAYS=365
ADMIN_BOOTSTRAP_KEY=

# Optional: server-side Supabase token validation (can reuse the client values).
# SUPABASE_URL=
# SUPABASE_ANON_KEY=


# =============== Production (Vercel) notes ===============
# • Build: `npm run build` → static files in `dist/`.
# • vercel.json:
#     - redirects www → apex
#     - rewrites /(.*) → /index.html EXCEPT /api/**, /assets/**, /fonts/**
#       and any path ending in a real file extension.
# • The Node API (`server/`) must be hosted elsewhere. Either:
#   (a) set VITE_API_URL to a public HTTPS API host, OR
#   (b) add a Vercel rewrite proxying /api/:path* to that host.
