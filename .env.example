# Copy to `.env` for the API process (same folder as package.json). Never commit real secrets.
#
# --- Supabase Auth (client + server token validation) ---
# Create a project at https://supabase.com — same values for Vite (prefix VITE_) and optional server-side:
#   VITE_SUPABASE_URL=https://xxxx.supabase.co
#   VITE_SUPABASE_ANON_KEY=eyJ...
# Server (optional, for /api/auth/supabase-oauth user fetch): can reuse:
#   SUPABASE_URL=https://xxxx.supabase.co
#   SUPABASE_ANON_KEY=eyJ...
# Vercel: add the VITE_* variables in Project → Settings → Environment Variables (Production + Preview).
# Social login UI is enabled by default when these are set; set VITE_SOCIAL_LOGIN_ENABLED=false to disable.

# --- Server ---
PORT=4000
SUPER_ADMIN_EMAIL=lahcenm534@gmail.com
SUPER_ADMIN_WHATSAPP=+212780290270
SUPER_ADMIN_NAME=LAHCEN EL MOUTAOUAKIL
SUPER_ADMIN_PASSWORD=
JWT_SECRET=change-me-in-production
JWT_EXPIRES_DAYS=365
# Same value as VITE_ADMIN_BOOTSTRAP_KEY below (16+ chars) for passwordless admin bootstrap
ADMIN_BOOTSTRAP_KEY=

# --- Client (Vite) — use `.env.production` or `.env.local` for production overrides; rebuild after changes ---
#
# Registered domain: smartal-idarapro.com — set ONE canonical URL (HTTPS, no trailing slash):
#   VITE_PUBLIC_APP_URL=https://smartal-idarapro.com
# Or subdomain:
#   VITE_PUBLIC_APP_URL=https://www.smartal-idarapro.com
#
# Public site URL for referral links, TL magic links, and `/dept/...` share URLs.
# Set when the browser cannot infer the correct origin (reverse proxy, CDN, wrong Host header).
# VITE_PUBLIC_APP_URL=https://smartal-idarapro.com

# If the SPA is served under a subpath (must match hosting / CDN path), set it with leading slash.
# Example: /saas/  → app lives at https://domain.com/saas/
# VITE_BASE_PATH=/

# Optional: full API URL prefix when not same-origin `/api` (no trailing slash).
# Same host: leave unset. Split API host example: https://api.smartal-idarapro.com/api
# VITE_API_URL=

# Optional: same ADMIN_BOOTSTRAP_KEY — enables POST /api/auth/admin-bootstrap from the client build
# VITE_ADMIN_BOOTSTRAP_KEY=
# VITE_ADMIN_AUTO_LOGIN=true

# --- Production hosting notes (Vercel) ---
# • Build: `npm run build` → static files in `dist/`. vercel.json rewrites /(.*) → /index.html.
# • Serve `dist/index.html` for all non-file routes (SPA fallback).
# • API: the Node server (`server/index.ts`) is NOT deployed on Vercel. Host it elsewhere
#   (Render/Railway/Fly/VM) and set `VITE_API_URL=https://your-api-host/api` at build time,
#   or port it to Vercel serverless functions.
# • Routes are client-side only: there is no `/src` in public URLs; Vite bundles assets under `/assets/`.
